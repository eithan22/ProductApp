@{
    ViewData["Title"] = "Inicio";
    var empresa = Context.Session.GetString("EMPRESA") ?? "ProductApp";
    var nombre = Context.Session.GetString("NOMBRE");
    var rol = Context.Session.GetString("ROL");
}

<div class="container">

    <!-- 🔥 HERO / BIENVENIDA -->
    <div class="card card-custom p-4 mb-4 text-center">

        <h1 class="fw-bold">Bienvenido a @empresa</h1>

        @if (!string.IsNullOrEmpty(nombre))
        {
            <p class="mt-2 mb-0">¡Hola, <strong>@nombre</strong>! <span class="text-muted">(@rol)</span></p>
        }

        <p class="text-muted mt-2">
            Sistema de gestión moderno para administrar tus Ventas de forma eficiente.
        </p>

    </div>

    <!-- 🔥 CARDS PRINCIPALES -->
    <div class="row">

        <!-- CLIENTES -->
        <div class="col-md-4 mb-4">
            <div class="card card-custom p-4 text-center">

                <i class="bi bi-people fs-1 text-primary"></i>

                <h5 class="mt-3">Clientes</h5>

                <p class="text-muted">
                    Gestiona, consulta y administra tus clientes.
                </p>

                <a asp-controller="Cliente" asp-action="Index" class="btn btn-primary btn-sm">
                    Ir a Clientes
                </a>

            </div>
        </div>

        <!-- FUTURO MODULO -->
        <div class="col-md-4 mb-4">
            <div class="card card-custom p-4 text-center">

                <i class="bi bi-bar-chart fs-1 text-success"></i>

                <h5 class="mt-3">Reportes</h5>

                <p class="text-muted">
                    Visualiza estadísticas y datos importantes.
                </p>

                <a asp-controller="Reporte" asp-action="Index" class="btn btn-success btn-sm">
                    Ir a Reportes
                </a>

            </div>
        </div>

        <!-- CONFIG -->
        <div class="col-md-4 mb-4">
            <div class="card card-custom p-4 text-center">

                <i class="bi bi-gear fs-1 text-dark"></i>

                <h5 class="mt-3">Configuración</h5>

                <p class="text-muted">
                    Ajusta opciones del sistema.
                </p>

                <a asp-controller="Configuracion" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    Ir a Configuración
                </a>

            </div>
        </div>

    </div>

</div>