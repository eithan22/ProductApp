@model Web.Models.Modelo_Productos.CategoriaModels.CreateCategoriaModel

@{
    ViewData["Title"] = "Nueva categoría";
}

<div class="surface-card p-4" style="max-width:560px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <form asp-action="Create">
        <div class="mb-3">
            <label asp-for="Nombre" class="form-label d-block">Nombre</label>
            <input asp-for="Nombre" class="form-control" placeholder="Ej: Electrónica" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Descripcion" class="form-label d-block">Descripción</label>
            <input asp-for="Descripcion" class="form-control" placeholder="Descripción de la categoría" />
            <span asp-validation-for="Descripcion" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "back") Volver</a>
            <button type="submit" class="btn-pa btn-pa-primary">Guardar categoría</button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
