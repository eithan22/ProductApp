@model ProductApp.Aplication.Common.PagedResult<Web.Models.Modelo_Productos.ProductoModels.ProductoModel>

@{
    ViewData["Title"] = "Productos";
    var incluirInactivos = ViewBag.IncluirInactivos as bool? ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">Catálogo de productos con su precio, costo y margen.</p>
    <a asp-action="Create" class="btn-pa btn-pa-primary">
        @await Html.PartialAsync("_Icon", "add") Nuevo producto
    </a>
</div>

<div class="surface-card p-3 mb-4">
    <form asp-action="Buscar" method="get" class="row g-2">
        <div class="col-md-5">
            <input type="text" name="nombre" class="form-control" placeholder="Buscar por nombre..." />
        </div>
        <div class="col-md-5">
            <input type="text" name="categoria" class="form-control" placeholder="Buscar por categoría..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn-pa btn-pa-outline w-100">@await Html.PartialAsync("_Icon", "search") Buscar</button>
        </div>
    </form>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="form-check">
        <input type="checkbox" class="form-check-input" id="incluirInactivos" name="incluirInactivos" value="true" onchange="this.form.submit()" @(incluirInactivos ? "checked" : "") />
        <label class="form-check-label" for="incluirInactivos">Mostrar inactivos</label>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="surface-card text-center text-muted py-5">No hay productos para mostrar.</div>
}

<div class="producto-grid">
    @foreach (var item in Model.Items)
    {
        var activo = item.Estado == "Activo";
        var margen = item.Precio > 0 ? Math.Round((item.Precio - item.Costo) / item.Precio * 100, 1) : 0;

        <div class="surface-card producto-card @(activo ? "activo" : "inactivo")">
            <span class="category-chip">@(item.Categoria ?? "Sin categoría")</span>

            <div class="producto-nombre">@item.Nombre</div>
            <div class="producto-desc">@item.Descripcion</div>

            <div class="producto-precio">@item.Precio.ToString("C")</div>
            <div class="producto-sub">Costo @item.Costo.ToString("C") · margen @margen%</div>

            <div class="producto-footer">
                <span class="status-pill @(activo ? "on" : "off")"><span class="dot"></span> @item.Estado</span>

                <div class="ledger-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="icon-btn" title="Ver">@await Html.PartialAsync("_Icon", "view")</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="icon-btn" title="Editar">@await Html.PartialAsync("_Icon", "edit")</a>

                    @if (activo)
                    {
                        <form asp-action="Disable" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="icon-btn danger" title="Desactivar">@await Html.PartialAsync("_Icon", "trash")</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Enable" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="icon-btn" title="Activar">@await Html.PartialAsync("_Icon", "check")</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

@await Html.PartialAsync("_Pagination", new Web.Models.Common.PaginationInfo { PageNumber = Model.PageNumber, TotalPages = Model.TotalPages })
