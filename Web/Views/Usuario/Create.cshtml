@model Web.Models.Modelo_Usuarios.UsuarioModels.CreateUsuarioModel
@using ProductApp.Domian.Common.Enums.EnumsUsuario

@{
    ViewData["Title"] = "Nuevo usuario";
}

<div class="surface-card p-4" style="max-width:640px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger"><div asp-validation-summary="All"></div></div>
    }

    <form asp-action="Create">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Nombre" class="form-label d-block"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label d-block"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="UserName" class="form-label d-block"></label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="FechaNacimiento" class="form-label d-block"></label>
                <input asp-for="FechaNacimiento" type="date" class="form-control" />
                <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="RolUsuario" class="form-label d-block"></label>
                <select asp-for="RolUsuario" asp-items="Html.GetEnumSelectList<RolUsuario>()" class="form-select"></select>
                <span asp-validation-for="RolUsuario" class="text-danger small"></span>
            </div>
            <div class="col-12 mb-4">
                <label asp-for="Password" class="form-label d-block"></label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "back") Volver</a>
            <button type="submit" class="btn-pa btn-pa-primary">Guardar</button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
