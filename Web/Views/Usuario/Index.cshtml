@model ProductApp.Aplication.Common.PagedResult<Web.Models.Modelo_Usuarios.UsuarioModels.UsuarioModel>

@{
    ViewData["Title"] = "Usuarios";
    var incluirInactivos = ViewBag.IncluirInactivos as bool? ?? false;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">Usuarios del sistema.</p>
    <a asp-action="Create" class="btn-pa btn-pa-primary">@await Html.PartialAsync("_Icon", "add") Nuevo usuario</a>
</div>

<form asp-action="Index" method="get" class="mb-3">
    <div class="form-check">
        <input type="checkbox" class="form-check-input" id="incluirInactivos" name="incluirInactivos" value="true" onchange="this.form.submit()" @(incluirInactivos ? "checked" : "") />
        <label class="form-check-label" for="incluirInactivos">Mostrar inactivos</label>
    </div>
</form>

<div class="surface-card p-2">
    @if (!Model.Items.Any())
    {
        <div class="text-center text-muted py-5">No hay usuarios registrados.</div>
    }

    @foreach (var item in Model.Items)
    {
        var activo = item.EstadoUsuario == "Activo";

        <div class="ledger-row">
            <div class="ledger-body">
                <div class="ledger-name">@item.Nombre</div>
                <div class="ledger-desc">@item.Email · @item.UserName</div>
            </div>

            <div class="ledger-meta">
                <span class="text-muted" style="font-size:.8rem;">@item.RolUsuario</span>
                <span class="mono text-muted" style="font-size:.8rem;">@item.Edad años</span>

                <span class="status-pill @(activo ? "on" : "off")">
                    <span class="dot"></span> @item.EstadoUsuario
                </span>

                <div class="ledger-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="icon-btn" title="Ver">@await Html.PartialAsync("_Icon", "view")</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="icon-btn" title="Editar">@await Html.PartialAsync("_Icon", "edit")</a>
                    <a asp-action="CambiarRol" asp-route-id="@item.Id" class="icon-btn" title="Cambiar rol">@await Html.PartialAsync("_Icon", "target")</a>
                    <a asp-action="ResetearPassword" asp-route-id="@item.Id" class="icon-btn" title="Resetear contraseña">@await Html.PartialAsync("_Icon", "reset")</a>

                    @if (activo)
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="icon-btn danger" title="Desactivar">@await Html.PartialAsync("_Icon", "trash")</a>
                    }
                    else
                    {
                        <form asp-action="Enable" asp-route-id="@item.Id" method="post" class="d-inline">
                            <button type="submit" class="icon-btn" title="Activar">@await Html.PartialAsync("_Icon", "check")</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>

@await Html.PartialAsync("_Pagination", new Web.Models.Common.PaginationInfo { PageNumber = Model.PageNumber, TotalPages = Model.TotalPages })
