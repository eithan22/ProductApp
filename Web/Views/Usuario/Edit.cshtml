@model Web.Models.Modelo_Usuarios.UsuarioModels.UpdateUsuarioModel

@{
    ViewData["Title"] = "Editar usuario";
}

<div class="surface-card p-4" style="max-width:640px;">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Nombre" class="form-label d-block"></label>
                <input asp-for="Nombre" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Email" class="form-label d-block"></label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="UserName" class="form-label d-block"></label>
                <input asp-for="UserName" class="form-control" />
            </div>
            <div class="col-md-6 mb-4">
                <label asp-for="FechaNacimiento" class="form-label d-block"></label>
                <input asp-for="FechaNacimiento" type="date" class="form-control" />
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "back") Volver</a>
            <button type="submit" class="btn-pa btn-pa-primary">Guardar cambios</button>
        </div>
    </form>
</div>
