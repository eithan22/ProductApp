@model Web.Models.Modelo_Usuarios.UsuarioModels.UpdateUsuarioModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-3">✏️ Editar Usuario</h2>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-action="Edit">

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="UserName" class="form-label"></label>
                        <input asp-for="UserName" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Edad" class="form-label"></label>
                        <input asp-for="Edad" class="form-control" />
                    </div>

                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">⬅️ Volver</a>
                    <button class="btn btn-warning">💾 Guardar cambios</button>
                </div>

            </form>

        </div>
    </div>
</div>