@model ProductApp.Aplication.Dtos.Modulo_Usuarios.UsuarioDto.ChangePasswordModel

@{
    ViewData["Title"] = "Cambiar mi contraseña";
}

<div class="surface-card p-4" style="max-width:480px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger"><div asp-validation-summary="All"></div></div>
    }

    <form asp-action="CambiarPassword">
        <div class="mb-3">
            <label asp-for="PasswordActual" class="form-label d-block"></label>
            <input asp-for="PasswordActual" type="password" class="form-control" />
        </div>

        <div class="mb-4">
            <label asp-for="PasswordNueva" class="form-label d-block"></label>
            <input asp-for="PasswordNueva" type="password" class="form-control" />
        </div>

        <div class="d-flex justify-content-end">
            <button type="submit" class="btn-pa btn-pa-primary">Cambiar contraseña</button>
        </div>
    </form>
</div>
