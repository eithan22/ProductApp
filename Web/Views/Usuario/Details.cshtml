@model Web.Models.Modelo_Usuarios.UsuarioModels.UsuarioModel

@{
    ViewData["Title"] = "Detalle Usuario";
}

<div class="container mt-4">

    <h2 class="fw-bold mb-4">👁️ Detalle del Usuario</h2>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label>ID</label>
                    <div>@Model.Id</div>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Nombre</label>
                    <div>@Model.Nombre</div>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Email</label>
                    <div>@Model.Email</div>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Usuario</label>
                    <div>@Model.UserName</div>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Rol</label>
                    <div>@Model.RolUsuario</div>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Estado</label>
                    <div>
                        <span class="badge @(Model.EstadoUsuario == "Activo" ? "bg-success" : "bg-danger")">
                            @Model.EstadoUsuario
                        </span>
                    </div>
                </div>

            </div>

            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">✏️ Editar</a>
                <a asp-action="Index" class="btn btn-secondary">⬅️ Volver</a>
            </div>

        </div>
    </div>
</div>