@model Web.Models.Modelo_Usuarios.UsuarioModels.UsuarioModel

@{
    ViewData["Title"] = "Detalle de usuario";
    var activo = Model.EstadoUsuario == "Activo";
}

<div class="surface-card p-4" style="max-width:640px;">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <span class="mono text-muted" style="font-size:.8rem;">#@Model.Id</span>
            <h2 class="mt-1 mb-0">@Model.Nombre</h2>
        </div>
        <span class="status-pill @(activo ? "on" : "off")"><span class="dot"></span> @Model.EstadoUsuario</span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label d-block">Correo</label>
            <div>@Model.Email</div>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label d-block">Usuario</label>
            <div>@Model.UserName</div>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label d-block">Rol</label>
            <div>@Model.RolUsuario</div>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-2">
        <a asp-action="Index" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "back") Volver</a>
        <div class="d-flex gap-2">
            <a asp-action="CambiarRol" asp-route-id="@Model.Id" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "target") Cambiar rol</a>
            <a asp-action="ResetearPassword" asp-route-id="@Model.Id" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "reset") Resetear contraseña</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-pa btn-pa-primary">@await Html.PartialAsync("_Icon", "edit") Editar</a>
        </div>
    </div>
</div>
