@model Web.Models.Modelo_Usuarios.UsuarioModels.UsuarioModel

@{
    ViewData["Title"] = "Desactivar usuario";
}

<div class="surface-card p-4" style="max-width:640px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">@Html.ValidationSummary(false, "", new { @class = "mb-0" })</div>
    }

    <div class="alert" style="background:var(--color-danger-soft); color:var(--color-danger); border:none;">
        Esta acción desactivará al usuario <strong>@Model.Nombre</strong>.
    </div>

    <div class="row mb-3">
        <div class="col-md-6 mb-2">
            <label class="form-label d-block">Correo</label>
            <div>@Model.Email</div>
        </div>
        <div class="col-md-6 mb-2">
            <label class="form-label d-block">Usuario</label>
            <div>@Model.UserName</div>
        </div>
        <div class="col-md-6 mb-2">
            <label class="form-label d-block">Rol</label>
            <div>@Model.RolUsuario</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-pa btn-pa-outline">Cancelar</a>
            <button type="submit" class="btn-pa btn-pa-danger">@await Html.PartialAsync("_Icon", "trash") Desactivar usuario</button>
        </div>
    </form>
</div>
