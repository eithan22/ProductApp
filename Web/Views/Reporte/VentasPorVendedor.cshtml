@model List<Web.Models.Modelo_Reportes.ReporteModels.VentaPorVendedorModel>

@{
    ViewData["Title"] = "Ventas por vendedor";
    var desde = ViewBag.Desde as DateTime?;
    var hasta = ViewBag.Hasta as DateTime?;
    var usuarioId = ViewBag.UsuarioId as int?;
}

<a asp-action="Index" class="btn-pa btn-pa-outline mb-3">@await Html.PartialAsync("_Icon", "back") Reportes</a>

<div class="surface-card p-3 mb-4">
    <form asp-action="VentasPorVendedor" method="get" class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Desde</label>
            <input type="date" name="desde" class="form-control" value="@(desde?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Hasta</label>
            <input type="date" name="hasta" class="form-control" value="@(hasta?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label">ID de vendedor (solo Administrador)</label>
            <input type="number" name="usuarioId" class="form-control" value="@usuarioId" placeholder="Todos" />
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn-pa btn-pa-primary w-100">@await Html.PartialAsync("_Icon", "search") Filtrar</button>
            <a asp-action="VentasPorVendedor" class="btn-pa btn-pa-outline w-100">@await Html.PartialAsync("_Icon", "reset") Limpiar</a>
        </div>
    </form>
</div>

@if (Model.Any())
{
    <div class="surface-card p-3 mb-4">
        <canvas id="chartVentasPorVendedor" height="90"></canvas>
    </div>
}

<div class="surface-card p-2">
    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">No hay ventas en el período seleccionado.</div>
    }

    @foreach (var item in Model)
    {
        <div class="ledger-row">
            <div class="ledger-body">
                <div class="ledger-name">@item.NombreVendedor</div>
                <div class="ledger-desc">@item.CantidadOrdenes órdenes</div>
            </div>
            <div class="ledger-meta">
                <span class="mono">@Html.Moneda(item.Total)</span>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => x.NombreVendedor)));
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => x.Total)));
    if (labels.length > 0) {
        new Chart(document.getElementById('chartVentasPorVendedor'), {
            type: 'bar',
            data: { labels: labels, datasets: [{ label: 'Total vendido', data: data, backgroundColor: '#14503F' }] },
            options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
        });
    }
</script>
}
