@model List<Web.Models.Modelo_Reportes.ReporteModels.InventarioActualModel>

@{
    ViewData["Title"] = "Inventario actual";
    var totalBajo = Model.Count(i => i.StockBajo);
    var totalNormal = Model.Count() - totalBajo;
}

<a asp-action="Index" class="btn-pa btn-pa-outline mb-3">@await Html.PartialAsync("_Icon", "back") Reportes</a>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="surface-card stat-mini">
            <div class="label">Productos con inventario</div>
            <div class="value">@Model.Count()</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="surface-card stat-mini">
            <div class="label">En stock bajo</div>
            <div class="value" style="color:var(--color-danger)">@totalBajo</div>
        </div>
    </div>
    <div class="col-md-4">
        @if (Model.Any())
        {
            <div class="surface-card p-2" style="max-width:180px; margin:0 auto;">
                <canvas id="chartInventario"></canvas>
            </div>
        }
    </div>
</div>

<div class="surface-card p-2">
    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">No hay registros de inventario.</div>
    }

    @foreach (var item in Model)
    {
        <div class="ledger-row">
            <div class="ledger-body">
                <div class="ledger-name">@item.NombreProducto</div>
                <div class="ledger-desc mono">@item.CantidadActual en stock · mínimo @item.CantidadMinima</div>
            </div>
            <div class="ledger-meta">
                <span class="status-pill @(item.StockBajo ? "off" : "on")">
                    <span class="dot"></span> @(item.StockBajo ? "Stock bajo" : "Normal")
                </span>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const chartInventarioEl = document.getElementById('chartInventario');
    if (chartInventarioEl) {
        new Chart(chartInventarioEl, {
            type: 'doughnut',
            data: {
                labels: ['Normal', 'Stock bajo'],
                datasets: [{ data: [@totalNormal, @totalBajo], backgroundColor: ['#14503F', '#8C3B2E'] }]
            },
            options: { plugins: { legend: { position: 'bottom' } } }
        });
    }
</script>
}
