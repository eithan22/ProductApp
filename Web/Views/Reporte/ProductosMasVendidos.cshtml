@model List<Web.Models.Modelo_Reportes.ReporteModels.ProductoMasVendidoModel>

@{
    ViewData["Title"] = "Productos más vendidos";
    var desde = ViewBag.Desde as DateTime?;
    var hasta = ViewBag.Hasta as DateTime?;
    var top = ViewBag.Top as int? ?? 10;
}

<a asp-action="Index" class="btn-pa btn-pa-outline mb-3">@await Html.PartialAsync("_Icon", "back") Reportes</a>

<div class="surface-card p-3 mb-4">
    <form asp-action="ProductosMasVendidos" method="get" class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Desde</label>
            <input type="date" name="desde" class="form-control" value="@(desde?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Hasta</label>
            <input type="date" name="hasta" class="form-control" value="@(hasta?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Top</label>
            <input type="number" name="top" class="form-control" value="@top" min="1" />
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn-pa btn-pa-primary w-100">@await Html.PartialAsync("_Icon", "search") Filtrar</button>
            <a asp-action="ProductosMasVendidos" class="btn-pa btn-pa-outline w-100">@await Html.PartialAsync("_Icon", "reset") Limpiar</a>
        </div>
    </form>
</div>

@if (Model.Any())
{
    <div class="surface-card p-3 mb-4">
        <canvas id="chartProductosMasVendidos" height="90"></canvas>
    </div>
}

<div class="surface-card p-2">
    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">No hay ventas en el período seleccionado.</div>
    }

    @{ var posicion = 0; }
    @foreach (var item in Model)
    {
        posicion++;
        <div class="ledger-row">
            <div class="ledger-body">
                <div class="ledger-name">#@posicion — @item.NombreProducto</div>
            </div>
            <div class="ledger-meta">
                <span class="mono">@item.CantidadVendida unidades</span>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => x.NombreProducto)));
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => x.CantidadVendida)));
    if (labels.length > 0) {
        new Chart(document.getElementById('chartProductosMasVendidos'), {
            type: 'bar',
            data: { labels: labels, datasets: [{ label: 'Unidades vendidas', data: data, backgroundColor: '#14503F' }] },
            options: { indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
        });
    }
</script>
}
