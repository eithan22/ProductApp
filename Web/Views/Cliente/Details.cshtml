@model Web.Models.ClienteModels.ClienteModel

@{
    ViewData["Title"] = "Detalle de cliente";
    var activo = Model.Estado == "Activo";
}

<div class="surface-card p-4" style="max-width:680px;">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <span class="mono text-muted" style="font-size:.8rem;">#@Model.Id</span>
            <h2 class="mt-1 mb-0">@Model.Nombre</h2>
        </div>
        <span class="status-pill @(activo ? "on" : "off")"><span class="dot"></span> @Model.Estado</span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label d-block">Correo</label>
            <div>@Model.Email</div>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label d-block">Teléfono</label>
            <div>@Model.Telefono</div>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label d-block">Cédula</label>
            <div class="mono">@Model.Cedula</div>
        </div>
        <div class="col-12 mb-3">
            <label class="form-label d-block">Dirección</label>
            <div>@Model.Direccion</div>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-2">
        <a asp-action="Index" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "back") Volver</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-pa btn-pa-primary">@await Html.PartialAsync("_Icon", "edit") Editar</a>
    </div>
</div>
