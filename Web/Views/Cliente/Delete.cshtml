@model Web.Models.ClienteModels.ClienteModel

@{
    ViewData["Title"] = "Desactivar cliente";
}

<div class="surface-card p-4" style="max-width:680px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false, "", new { @class = "mb-0" })
        </div>
    }

    <div class="alert" style="background:var(--color-danger-soft); color:var(--color-danger); border:none;">
        Esta acción desactivará al cliente <strong>@Model.Nombre</strong>.
    </div>

    <div class="row mb-3">
        <div class="col-md-6 mb-2">
            <label class="form-label d-block">Correo</label>
            <div>@Model.Email</div>
        </div>
        <div class="col-md-6 mb-2">
            <label class="form-label d-block">Teléfono</label>
            <div>@Model.Telefono</div>
        </div>
        <div class="col-md-6 mb-2">
            <label class="form-label d-block">Cédula</label>
            <div class="mono">@Model.Cedula</div>
        </div>
        <div class="col-12 mb-2">
            <label class="form-label d-block">Dirección</label>
            <div>@Model.Direccion</div>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-pa btn-pa-outline">Cancelar</a>
            <button type="submit" class="btn-pa btn-pa-danger">@await Html.PartialAsync("_Icon", "trash") Desactivar cliente</button>
        </div>
    </form>
</div>
