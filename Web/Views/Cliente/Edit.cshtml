@model Web.Models.ClienteModels.UpdateClientemodel

@{
    ViewData["Title"] = "Editar cliente";
}

<div class="surface-card p-4" style="max-width:680px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger"><div asp-validation-summary="All"></div></div>
    }

    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Nombre" class="form-label d-block"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Correo" class="form-label d-block"></label>
                <input asp-for="Correo" class="form-control" />
                <span asp-validation-for="Correo" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Telefono" class="form-label d-block"></label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Cedula" class="form-label d-block"></label>
                <input asp-for="Cedula" class="form-control" />
                <span asp-validation-for="Cedula" class="text-danger small"></span>
            </div>
            <div class="col-12 mb-4">
                <label asp-for="Direccion" class="form-label d-block"></label>
                <input asp-for="Direccion" class="form-control" />
                <span asp-validation-for="Direccion" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "back") Volver</a>
            <button type="submit" class="btn-pa btn-pa-primary">Guardar cambios</button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
