@model Web.Models.Modelo_Ventas.OrdenModels.CreateOrdenModel

@{
    ViewData["Title"] = "Nueva orden";
    var clientes = ViewBag.Clientes as List<Web.Models.ClienteModels.ClienteModel>;
}

<div class="surface-card p-4" style="max-width:560px;">
    <p class="text-muted">Selecciona el cliente para iniciar la orden. Los productos se agregan en el siguiente paso.</p>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger"><div asp-validation-summary="All"></div></div>
    }

    <form asp-action="Create">
        <div class="mb-4">
            <label asp-for="ClienteId" class="form-label d-block">Cliente</label>
            <select asp-for="ClienteId" class="form-select">
                <option value="">-- Selecciona un cliente --</option>
                @if (clientes != null)
                {
                    @foreach (var c in clientes)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                }
            </select>
            <span asp-validation-for="ClienteId" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-pa btn-pa-outline">@await Html.PartialAsync("_Icon", "back") Volver</a>
            <button type="submit" class="btn-pa btn-pa-primary">Crear orden</button>
        </div>
    </form>
</div>
