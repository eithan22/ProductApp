@model Web.Models.Modelo_Configuracion.ConfiguracionModel

@{
    ViewData["Title"] = "Configuración";
}

<div class="surface-card p-4" style="max-width:640px;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger"><div asp-validation-summary="All"></div></div>
    }

    <form asp-action="Index">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="NombreEmpresa" class="form-label d-block"></label>
                <input asp-for="NombreEmpresa" class="form-control" />
                <span asp-validation-for="NombreEmpresa" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Moneda" class="form-label d-block"></label>
                <select asp-for="Moneda" class="form-select">
                    <option value="USD">USD - Dólar estadounidense</option>
                    <option value="DOP">DOP - Peso dominicano</option>
                    <option value="EUR">EUR - Euro</option>
                    <option value="MXN">MXN - Peso mexicano</option>
                </select>
                <span asp-validation-for="Moneda" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="CantidadMinimaInventarioDefecto" class="form-label d-block"></label>
                <input asp-for="CantidadMinimaInventarioDefecto" type="number" min="0" class="form-control" />
                <span asp-validation-for="CantidadMinimaInventarioDefecto" class="text-danger small"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="DuracionTokenMinutos" class="form-label d-block"></label>
                <input asp-for="DuracionTokenMinutos" type="number" min="1" class="form-control" />
                <span asp-validation-for="DuracionTokenMinutos" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <button type="submit" class="btn-pa btn-pa-primary">Guardar cambios</button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
