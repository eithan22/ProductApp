@using Microsoft.AspNetCore.Http

@{
    var token = Context.Session.GetString("TOKEN");
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProductApp</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-3">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(token))
    {
        <div class="app-sidebar">
            <div class="brand">ProductApp</div>

            <nav>
                <a asp-controller="Home" asp-action="Index" class="@(controller == "Home" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "home") Inicio
                </a>
                <a asp-controller="Cliente" asp-action="Index" class="@(controller == "Cliente" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "users") Clientes
                </a>
                <a asp-controller="Categoria" asp-action="Index" class="@(controller == "Categoria" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "tag") Categorías
                </a>
                <a asp-controller="Producto" asp-action="Index" class="@(controller == "Producto" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "box") Productos
                </a>
                <a asp-controller="Inventario" asp-action="Index" class="@(controller == "Inventario" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "layers") Inventario
                </a>
                <a asp-controller="Orden" asp-action="Index" class="@(controller == "Orden" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "receipt") Órdenes
                </a>
                <a asp-controller="Reporte" asp-action="Index" class="@(controller == "Reporte" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "chart") Reportes
                </a>
                <a asp-controller="Usuario" asp-action="Index" class="@(controller == "Usuario" ? "active" : "")">
                    @await Html.PartialAsync("_Icon", "users") Usuarios
                </a>
            </nav>

            <a asp-controller="Auth" asp-action="Logout" class="logout">
                @await Html.PartialAsync("_Icon", "logout") Cerrar sesión
            </a>
        </div>

        <div class="app-content">
            <div class="app-topbar">
                <h1>@ViewData["Title"]</h1>
            </div>

            @RenderBody()
        </div>
    }
    else
    {
        <div class="auth-container">
            <div class="auth-box">
                @RenderBody()
            </div>
        </div>
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>