@model Web.Models.Modelo_Usuarios.UsuarioModels.AuthModel.RegisterModel

@{
    ViewData["Title"] = "Registro";
}

<div class="mb-4 text-center">
    <h2 class="fw-bold">Crear Cuenta</h2>
    <p class="text-muted">
        Completa la información para registrarte
    </p>
</div>

<form asp-action="Register" method="post">

    @Html.AntiForgeryToken()

    <!-- ERRORES GENERALES -->
    <div asp-validation-summary="ModelOnly"
         class="alert alert-danger">
    </div>

    <div class="row">

        <!-- NOMBRE -->
        <div class="col-md-6 mb-3">

            <label asp-for="Nombre"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="Nombre"
                   class="form-control"
                   placeholder="Juan Pérez" />

            <span asp-validation-for="Nombre"
                  class="text-danger">
            </span>

        </div>

        <!-- FECHA DE NACIMIENTO -->
        <div class="col-md-6 mb-3">

            <label asp-for="FechaNacimiento"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="FechaNacimiento"
                   type="date"
                   class="form-control" />

            <span asp-validation-for="FechaNacimiento"
                  class="text-danger">
            </span>

        </div>

        <!-- EMAIL -->
        <div class="col-md-6 mb-3">

            <label asp-for="Email"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="Email"
                   class="form-control"
                   placeholder="correo@email.com" />

            <span asp-validation-for="Email"
                  class="text-danger">
            </span>

        </div>

        <!-- USERNAME -->
        <div class="col-md-6 mb-3">

            <label asp-for="UserName"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="UserName"
                   class="form-control"
                   placeholder="usuario123" />

            <span asp-validation-for="UserName"
                  class="text-danger">
            </span>

        </div>

        <!-- PASSWORD -->
        <div class="col-md-6 mb-3">

            <label asp-for="Password"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="Password"
                   type="password"
                   class="form-control" />

            <span asp-validation-for="Password"
                  class="text-danger">
            </span>

        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="col-md-6 mb-3">

            <label asp-for="ConfirmPassword"
                   class="form-label fw-semibold">
            </label>

            <input asp-for="ConfirmPassword"
                   type="password"
                   class="form-control" />

            <span asp-validation-for="ConfirmPassword"
                  class="text-danger">
            </span>

        </div>

    </div>

    <!-- BOTON -->
    <div class="d-grid mt-3">

        <button type="submit"
                class="btn-pa btn-pa-primary justify-content-center">
            Crear Cuenta
        </button>

    </div>

    <!-- LOGIN -->
    <div class="text-center mt-3">

        <small>
            ¿Ya tienes cuenta?

            <a asp-controller="Auth"
                   asp-action="Login"
                   class="fw-semibold">
                Iniciar sesión
            </a>

        </small>

    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
